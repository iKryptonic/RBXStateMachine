local ContextObject = {}
ContextObject.__index = ContextObject

function ContextObject.new()
    local self = setmetatable({}, ContextObject)
    self:Init()
    return self
end

function ContextObject:Init()
    self._Name = "ContextObject"
    self._Class = "ContextObject"
    self._CreateTime = os.time()
end

function ContextObject:Extend(subclassName)
    local subclass = setmetatable({}, self)
    subclass.__index = subclass
    subclass._Class = subclassName or "Subclass"
    subclass._Super = self
    
    function subclass.new(...)
        local instance = setmetatable({}, subclass)
        if instance.Init then
            instance:Init(...)
        end
        return instance
    end
    
    return subclass
end
    
function ContextObject:Bind(eventName, callback)
    self._Listeners = self._Listeners or {}
    self._Listeners[eventName] = self._Listeners[eventName] or {}
    
    table.insert(self._Listeners[eventName], callback)
    
    return {
        Unbind = function()
            if not self._Listeners or not self._Listeners[eventName] then return end
            for i, cb in ipairs(self._Listeners[eventName]) do
                if cb == callback then
                    table.remove(self._Listeners[eventName], i)
                    break
                end
            end
        end
    }
end

function ContextObject:Fire(eventName, ...)
    if not self._Listeners or not self._Listeners[eventName] then return end
    
    for _, callback in ipairs(self._Listeners[eventName]) do
        task.spawn(function(...)
            local ok, err = pcall(callback, ...)
            if not ok then
                warn(string.format("[ContextObject] Listener error on '%s': %s", tostring(eventName), tostring(err)))
            end
        end, ...)
    end
end

function ContextObject:Destroy()
    if self.Fire then
        self:Fire("Destroying")
    end
    self._Listeners = nil
    self._Class = nil
    self._Name = nil
    setmetatable(self, nil)
end

return ContextObject